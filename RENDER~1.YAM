# Render Blueprint — deploys Fortune Mill as a free web service.
# Docs: https://render.com/docs/blueprint-spec
services:
  - type: web
    name: fortune-mill
    runtime: node
    plan: free
    # No real dependencies, but this is a safe no-op if you add some later.
    buildCommand: npm install
    startCommand: node server.js
    # Render injects PORT automatically; server.js already reads process.env.PORT.
    healthCheckPath: /
    autoDeploy: true
